{
  "manifest_version": 3,
  "name": "Nowsze Horyzonty",
  "version": "0.1.1",
  "description": "Dodaje do kalendarza Nowych Horyzontów oceny IMDb, gatunki, zwiastuny, liczbę metek, godziny zakończenia i opisy filmów.",
  "author": "Filip Wachowiak",
  "homepage_url": "https://github.com/filipw01/nowsze-horyzonty",
  "icons": {
    "128": "nh-plus-128.png"
  },
  "developer": {
    "name": "Filip Wachowiak",
    "url": "https://github.com/filipw01"
  },
  "content_scripts": [
    {
      "matches": ["https://www.nowehoryzonty.pl/program/kalendarz*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "nowsze-horyzonty@filipw01.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
