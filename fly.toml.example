app = "nowsze-horyzonty"
primary_region = "waw"

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "8787"
  CORS_ORIGINS = "https://www.nowehoryzonty.pl"

[http_service]
  internal_port = 8787
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

  [[http_service.checks]]
    interval = "30s"
    timeout = "5s"
    grace_period = "10s"
    method = "GET"
    path = "/healthz"
